<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Turma do Código v2</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --purple:#534AB7;--purple-light:#EEEDFE;--purple-mid:#CECBF6;
  --teal:#1D9E75;--teal-light:#E1F5EE;--teal-mid:#9FE1CB;
  --amber:#BA7517;--amber-light:#FAEEDA;--amber-mid:#FAC775;
  --green:#3B6D11;--green-light:#EAF3DE;--green-mid:#C0DD97;
  --red:#A32D2D;--red-light:#FCEBEB;--red-mid:#F7C1C1;
  --bg:#f8f7ff;--border:#e0dff5;--text:#1a1a2e;--muted:#666;
  --mono:'Courier New',monospace;
}
body{font-family:'Segoe UI',system-ui,sans-serif;background:var(--bg);color:var(--text);font-size:15px;line-height:1.6}

/* ── LOGIN ── */
#login-screen{display:flex;align-items:center;justify-content:center;min-height:100vh;background:var(--purple)}
.login-card{background:#fff;border-radius:16px;padding:2.5rem;width:360px;text-align:center}
.login-logo{font-size:48px;margin-bottom:.5rem}
.login-card h1{font-size:22px;font-weight:700;color:var(--purple);margin-bottom:.25rem}
.login-card p{font-size:13px;color:var(--muted);margin-bottom:1.5rem}
.login-field{width:100%;padding:10px 14px;border:1.5px solid var(--border);border-radius:8px;font-size:14px;margin-bottom:10px;outline:none}
.login-field:focus{border-color:var(--purple)}
.login-btn{width:100%;padding:11px;background:var(--purple);color:#fff;border:none;border-radius:8px;font-size:15px;font-weight:700;cursor:pointer;margin-bottom:8px}
.login-btn:hover{background:#3C3489}
.login-btn.secondary{background:#fff;color:var(--purple);border:1.5px solid var(--purple)}
.login-btn.secondary:hover{background:var(--purple-light)}
.login-error{font-size:12px;color:var(--red);margin-top:4px;display:none}

/* ── APP LAYOUT ── */
#app{display:none}
.header{background:var(--purple);color:#fff;padding:.75rem 1.5rem;display:flex;align-items:center;gap:12px}
.header h1{font-size:18px;font-weight:700}
.header-sub{font-size:12px;opacity:.8}
.header-right{margin-left:auto;display:flex;align-items:center;gap:10px}
.stars-bar{background:rgba(255,255,255,.15);padding:5px 12px;border-radius:999px;font-size:13px;font-weight:700}
.user-badge{background:rgba(255,255,255,.2);padding:5px 12px;border-radius:999px;font-size:13px;font-weight:600}
.logout-btn{background:rgba(255,255,255,.15);border:none;color:#fff;padding:5px 10px;border-radius:6px;cursor:pointer;font-size:12px}
.logout-btn:hover{background:rgba(255,255,255,.25)}

/* ── MAIN ── */
.main{display:grid;grid-template-columns:250px 1fr;min-height:calc(100vh - 56px)}
.sidebar{background:#fff;border-right:1px solid var(--border);padding:1rem;overflow-y:auto}
.lang-tabs{display:flex;gap:4px;margin-bottom:10px;flex-wrap:wrap}
.lang-tab{flex:1;padding:6px;border-radius:8px;border:1.5px solid var(--border);background:transparent;cursor:pointer;font-size:12px;font-weight:600;color:var(--muted);min-width:56px}
.lang-tab.act-cpp{background:var(--purple);color:#fff;border-color:var(--purple)}
.lang-tab.act-cs{background:var(--teal);color:#fff;border-color:var(--teal)}
.lang-tab.act-py{background:var(--amber);color:#fff;border-color:var(--amber)}
.sidebar-title{font-size:10px;font-weight:700;color:var(--muted);letter-spacing:.08em;text-transform:uppercase;margin-bottom:6px}
.progress-bar{height:5px;background:var(--border);border-radius:999px;overflow:hidden;margin:8px 0 4px}
.progress-fill{height:100%;background:var(--purple);border-radius:999px;transition:.4s}
.prog-label{font-size:10px;color:var(--muted);margin-bottom:10px}
.mission-item{display:flex;align-items:center;gap:7px;padding:7px 8px;border-radius:8px;cursor:pointer;margin-bottom:2px;border:1px solid transparent}
.mission-item:hover{background:var(--purple-light)}
.mission-item.active{background:var(--purple-light);border-color:var(--purple-mid)}
.mission-item.done .m-icon{background:var(--green-mid);color:var(--green)}
.mission-item.locked{opacity:.4;cursor:not-allowed}
.m-icon{width:26px;height:26px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:12px;background:var(--purple-mid);color:var(--purple);flex-shrink:0;font-weight:700}
.m-title{font-size:12px;font-weight:600;line-height:1.3}
.m-sub{font-size:10px;color:var(--muted)}

/* ── CONTENT ── */
.content{padding:1.25rem;overflow-y:auto;max-height:calc(100vh - 56px)}
.welcome{text-align:center;padding:2.5rem 1.5rem}
.welcome-big{font-size:44px;margin-bottom:.75rem}
.welcome h2{font-size:20px;font-weight:700;margin-bottom:.4rem}
.welcome p{font-size:14px;color:var(--muted);max-width:360px;margin:0 auto 1.25rem}
.start-btn{padding:10px 28px;background:var(--purple);color:#fff;border:none;border-radius:10px;font-size:15px;font-weight:700;cursor:pointer}

/* ── MISSÃO ── */
.mission-header{display:flex;align-items:center;gap:10px;margin-bottom:.75rem}
.mission-emoji{font-size:28px}
.mission-title-wrap h2{font-size:16px;font-weight:700}
.mission-title-wrap p{font-size:12px;color:var(--muted)}
.lang-badge{display:inline-block;font-size:10px;font-weight:700;padding:2px 8px;border-radius:999px;margin-left:5px}
.badge-cpp{background:var(--purple-mid);color:#3C3489}
.badge-cs{background:var(--teal-mid);color:#085041}
.badge-py{background:var(--amber-mid);color:#633806}
.analogy{background:var(--teal-light);border-radius:10px;padding:.6rem .9rem;margin-bottom:.75rem;font-size:13px;display:flex;gap:8px}
.concept{background:var(--amber-light);border-left:4px solid var(--amber);border-radius:0 8px 8px 0;padding:.6rem .9rem;margin-bottom:.75rem;font-size:13px}
.concept strong{color:var(--amber)}

/* ── EDITOR ── */
.editor-wrap{border:2px solid #313244;border-radius:10px;overflow:hidden;margin-bottom:.6rem}
.editor-bar{display:flex;align-items:center;gap:7px;padding:6px 10px;background:#1e1e2e}
.file-dot{width:9px;height:9px;border-radius:50%}
.dot-r{background:#ff5f57}.dot-y{background:#febc2e}.dot-g{background:#28c840}
.fname{font-family:var(--mono);font-size:11px;color:#cdd6f4;flex:1}
.ebtn{padding:3px 10px;border-radius:5px;border:none;cursor:pointer;font-size:11px;font-weight:600}
.ebtn-copy{background:#313244;color:#cdd6f4}.ebtn-copy:hover{background:#45475a}
.ebtn-run{background:#a6e3a1;color:#1e1e2e}.ebtn-run:hover{background:#94e2d5}
.ebtn-web{background:#cba6f7;color:#1e1e2e}.ebtn-web:hover{background:#b4befe}
.code-area{width:100%;min-height:180px;background:#1e1e2e;color:#cdd6f4;font-family:var(--mono);font-size:12px;line-height:1.7;padding:12px;border:none;outline:none;resize:vertical;display:block;tab-size:2}
.inputs-panel{background:var(--purple-light);border:1px solid var(--purple-mid);border-radius:8px;padding:.6rem .9rem;margin-bottom:.6rem;display:none}
.inputs-panel.show{display:block}
.inputs-title{font-size:11px;font-weight:700;color:var(--purple);margin-bottom:6px}
.inp-row{display:flex;align-items:center;gap:8px;margin-bottom:5px}
.inp-row label{font-size:12px;min-width:100px}
.inp-row input{flex:1;padding:4px 8px;border:1.5px solid var(--purple-mid);border-radius:6px;background:#fff;font-family:var(--mono);font-size:12px}
.output-wrap{border:2px solid #313244;border-radius:10px;overflow:hidden;margin-bottom:.75rem}
.output-bar{background:#181825;padding:5px 10px;display:flex;align-items:center;justify-content:space-between}
.output-label{font-size:11px;color:#6c7086;display:flex;align-items:center;gap:5px}
.out-dot{width:7px;height:7px;border-radius:50%;background:#a6e3a1}
.output-body{background:#1e1e2e;color:#a6e3a1;font-family:var(--mono);font-size:12px;padding:12px;min-height:70px;white-space:pre-wrap;line-height:1.7}
.output-body.err{color:#f38ba8}
.output-body.wait{color:#6c7086;font-style:italic}

/* ── QUIZ ── */
.quiz-box{background:var(--purple-light);border:1.5px solid var(--purple-mid);border-radius:10px;padding:.75rem;margin-bottom:.75rem}
.quiz-q{font-size:13px;font-weight:600;margin-bottom:8px}
.quiz-opts{display:flex;flex-direction:column;gap:5px}
.quiz-opt{padding:7px 12px;border-radius:7px;border:1.5px solid var(--purple-mid);background:#fff;cursor:pointer;font-size:12px;text-align:left}
.quiz-opt:hover{background:var(--purple-mid)}
.quiz-opt.correct{background:var(--green-light);border-color:var(--green-mid);color:var(--green)}
.quiz-opt.wrong{background:var(--red-light);border-color:var(--red-mid);color:var(--red)}
.quiz-feedback{margin-top:7px;font-size:12px;font-weight:600;padding:5px 9px;border-radius:6px;display:none}
.quiz-feedback.ok{background:var(--green-light);color:var(--green)}
.quiz-feedback.no{background:var(--red-light);color:var(--red)}

/* ── CHALLENGE ── */
.challenge-box{background:#fff;border:2px dashed var(--border);border-radius:10px;padding:.75rem;margin-bottom:.75rem}
.challenge-title{font-size:13px;font-weight:700;color:var(--purple);margin-bottom:.4rem}
.challenge-text{font-size:12px;margin-bottom:.6rem;line-height:1.6}
.hint-btn{font-size:11px;color:var(--purple);background:var(--purple-light);border:1px solid var(--purple-mid);padding:3px 10px;border-radius:5px;cursor:pointer}
.hint-text{display:none;margin-top:7px;font-size:11px;color:var(--muted);background:var(--amber-light);padding:5px 9px;border-radius:6px}
.hint-text.show{display:block}

/* ── PERGUNTAS DA MISSÃO ── */
.qa-box{background:#fff;border:1.5px solid var(--border);border-radius:10px;padding:.75rem;margin-bottom:.75rem}
.qa-title{font-size:13px;font-weight:700;color:var(--text);margin-bottom:.6rem;display:flex;align-items:center;gap:6px}
.qa-list{display:flex;flex-direction:column;gap:8px;margin-bottom:.6rem;max-height:200px;overflow-y:auto}
.qa-item{background:var(--bg);border-radius:8px;padding:7px 10px;font-size:12px}
.qa-item .qa-who{font-weight:700;color:var(--purple);font-size:11px;margin-bottom:2px}
.qa-item .qa-resp{background:var(--green-light);border-radius:6px;padding:5px 8px;margin-top:4px;font-size:11px;color:var(--green);display:none}
.qa-item .qa-resp.show{display:block}
.qa-item .qa-time{font-size:10px;color:var(--muted)}
.qa-input-row{display:flex;gap:6px}
.qa-input{flex:1;padding:6px 10px;border:1.5px solid var(--border);border-radius:7px;font-size:12px;outline:none}
.qa-input:focus{border-color:var(--purple)}
.qa-send{padding:6px 14px;background:var(--purple);color:#fff;border:none;border-radius:7px;cursor:pointer;font-size:12px;font-weight:600}
.qa-send:hover{background:#3C3489}
.qa-empty{font-size:12px;color:var(--muted);text-align:center;padding:.5rem}

/* ── ACHIEVEMENT ── */
.ach-popup{display:none;background:var(--amber-light);border:2px solid var(--amber-mid);border-radius:10px;padding:.6rem .9rem;margin-bottom:.75rem;align-items:center;gap:10px}
.ach-popup.show{display:flex}
.ach-icon{font-size:24px}
.ach-text strong{display:block;font-size:13px;color:var(--amber)}
.ach-text span{font-size:11px;color:var(--muted)}

/* ── SITES ── */
.sites-section{margin-top:.4rem}
.sites-title{font-size:10px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.07em;margin-bottom:6px}
.sites-grid{display:grid;grid-template-columns:1fr 1fr;gap:6px}
.site-link{display:flex;align-items:center;gap:7px;padding:6px 10px;border:1.5px solid var(--border);border-radius:8px;text-decoration:none;background:#fff}
.site-link:hover{border-color:var(--purple);background:var(--purple-light)}
.site-icon{font-size:16px}
.site-name{font-size:12px;font-weight:600;color:var(--text)}
.site-tag{font-size:10px;color:var(--muted)}
.next-btn{width:100%;padding:10px;background:var(--purple);color:#fff;border:none;border-radius:9px;font-size:14px;font-weight:700;cursor:pointer;margin-top:.4rem}
.next-btn:disabled{background:var(--border);color:var(--muted);cursor:not-allowed}

/* ── PAINEL PROFESSOR ── */
#prof-panel{display:none;padding:1.25rem}
.prof-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:1rem}
.prof-header h2{font-size:18px;font-weight:700}
.prof-tabs{display:flex;gap:8px;margin-bottom:1rem}
.prof-tab{padding:7px 18px;border-radius:8px;border:1.5px solid var(--border);background:#fff;cursor:pointer;font-size:13px;font-weight:600;color:var(--muted)}
.prof-tab.active{background:var(--purple);color:#fff;border-color:var(--purple)}

/* ranking */
.rank-table{width:100%;border-collapse:collapse;background:#fff;border-radius:10px;overflow:hidden;border:1.5px solid var(--border)}
.rank-table th{background:var(--purple);color:#fff;padding:9px 12px;text-align:left;font-size:12px;font-weight:600}
.rank-table td{padding:9px 12px;font-size:13px;border-bottom:1px solid var(--border)}
.rank-table tr:last-child td{border-bottom:none}
.rank-table tr:hover td{background:var(--purple-light)}
.rank-pos{font-weight:700;color:var(--purple);width:32px}
.rank-medal{font-size:16px}
.stat-pill{display:inline-block;font-size:11px;font-weight:600;padding:2px 8px;border-radius:999px}
.pill-ok{background:var(--green-light);color:var(--green)}
.pill-err{background:var(--red-light);color:var(--red)}
.pill-pend{background:var(--amber-light);color:var(--amber)}

/* progresso alunos */
.student-cards{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:12px}
.student-card{background:#fff;border:1.5px solid var(--border);border-radius:10px;padding:.9rem}
.student-card-header{display:flex;align-items:center;gap:8px;margin-bottom:.6rem}
.student-avatar{width:36px;height:36px;border-radius:50%;background:var(--purple-light);color:var(--purple);display:flex;align-items:center;justify-content:center;font-weight:700;font-size:14px;flex-shrink:0}
.student-name{font-size:14px;font-weight:600}
.student-stats{font-size:11px;color:var(--muted)}
.mini-progress{height:4px;background:var(--border);border-radius:999px;overflow:hidden;margin:.4rem 0}
.mini-progress-fill{height:100%;background:var(--purple);border-radius:999px}
.mission-badges{display:flex;flex-wrap:wrap;gap:3px;margin-top:.4rem}
.mbadge{width:22px;height:22px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:11px;border:1.5px solid transparent}
.mbadge.done{background:var(--green-light);border-color:var(--green-mid);color:var(--green)}
.mbadge.todo{background:var(--bg);border-color:var(--border);color:var(--muted)}

/* perguntas painel */
.qa-prof-list{display:flex;flex-direction:column;gap:8px}
.qa-prof-item{background:#fff;border:1.5px solid var(--border);border-radius:10px;padding:.75rem}
.qa-prof-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:.4rem}
.qa-prof-who{font-size:12px;font-weight:700;color:var(--purple)}
.qa-prof-mission{font-size:11px;color:var(--muted)}
.qa-prof-text{font-size:13px;margin-bottom:.5rem}
.qa-resp-area{width:100%;padding:6px 10px;border:1.5px solid var(--border);border-radius:6px;font-size:12px;resize:none;outline:none;margin-bottom:5px}
.qa-resp-area:focus{border-color:var(--teal)}
.qa-resp-btn{padding:5px 14px;background:var(--teal);color:#fff;border:none;border-radius:6px;cursor:pointer;font-size:12px;font-weight:600}
.qa-resp-btn:hover{background:#0F6E56}
.qa-prof-resp{background:var(--green-light);border-radius:6px;padding:5px 9px;font-size:12px;color:var(--green);margin-top:4px;display:none}
.qa-prof-resp.show{display:block}
.qa-badge-pend{font-size:10px;font-weight:700;padding:2px 7px;border-radius:999px;background:var(--amber-light);color:var(--amber)}
.qa-badge-resp{font-size:10px;font-weight:700;padding:2px 7px;border-radius:999px;background:var(--green-light);color:var(--green)}
.empty-state{text-align:center;padding:2rem;color:var(--muted);font-size:13px}
.empty-state .empty-icon{font-size:36px;margin-bottom:.5rem}

/* senha professor */
.prof-lock{background:var(--amber-light);border:1.5px solid var(--amber-mid);border-radius:10px;padding:1rem;margin-bottom:1rem;display:flex;align-items:center;gap:10px}
.prof-lock input{padding:7px 12px;border:1.5px solid var(--border);border-radius:7px;font-size:13px;outline:none}
.prof-lock input:focus{border-color:var(--amber)}
.prof-lock button{padding:7px 16px;background:var(--amber);color:#fff;border:none;border-radius:7px;cursor:pointer;font-size:13px;font-weight:600}
.prof-lock-msg{font-size:12px;color:var(--red);margin-top:4px;display:none}
</style>
</head>
<body>

<!-- LOGIN -->
<div id="login-screen">
  <div class="login-card">
    <div class="login-logo">🚀</div>
    <h1>Turma do Código</h1>
    <p>Entre com seu nome para começar!</p>
    <input class="login-field" id="login-name" type="text" placeholder="Seu nome completo" maxlength="40">
    <select class="login-field" id="login-lang" style="cursor:pointer">
      <option value="cpp">C++</option>
      <option value="cs">C#</option>
      <option value="py">Python</option>
    </select>
    <button class="login-btn" onclick="doLogin()">Entrar como aluno</button>
    <button class="login-btn secondary" onclick="showProfLogin()">Entrar como professor</button>
    <div style="margin-top:10px;background:#f8f7ff;border-radius:8px;padding:8px 10px;display:none" id="prof-login-area">
      <input class="login-field" id="prof-pwd" type="password" placeholder="Senha do professor">
      <button class="login-btn" onclick="doProfLogin()">Acessar painel</button>
    </div>
    <div class="login-error" id="login-error"></div>
  </div>
</div>

<!-- APP -->
<div id="app">
  <div class="header">
    <span style="font-size:24px">🚀</span>
    <div><h1>Turma do Código</h1><div class="header-sub">Aprenda C++, C# e Python</div></div>
    <div class="header-right">
      <div class="stars-bar">⭐ <span id="star-count">0</span></div>
      <div class="user-badge" id="user-badge">Aluno</div>
      <button class="logout-btn" onclick="doLogout()">Sair</button>
    </div>
  </div>

  <div class="main" id="student-view">
    <div class="sidebar">
      <div class="lang-tabs">
        <button class="lang-tab act-cpp" id="tab-cpp" onclick="switchLang('cpp')">C++</button>
        <button class="lang-tab" id="tab-cs" onclick="switchLang('cs')">C#</button>
        <button class="lang-tab" id="tab-py" onclick="switchLang('py')">Python</button>
      </div>
      <div class="progress-bar"><div class="progress-fill" id="prog-fill" style="width:0%"></div></div>
      <div class="prog-label" id="prog-label">0 de 8 missões</div>
      <div class="sidebar-title">Missões</div>
      <div id="missions-list"></div>
    </div>
    <div class="content" id="content">
      <div class="welcome">
        <div class="welcome-big">🚀</div>
        <h2>Bem-vindo à Turma do Código!</h2>
        <p>Escolha C++, C# ou Python e comece sua primeira missão!</p>
        <button class="start-btn" onclick="startFirst()">Começar agora!</button>
      </div>
    </div>
  </div>

  <!-- PAINEL PROFESSOR -->
  <div id="prof-panel">
    <div class="prof-header">
      <h2>🎓 Painel do Professor</h2>
      <div style="font-size:13px;color:var(--muted)" id="prof-last-update"></div>
    </div>

    <!-- senha -->
    <div class="prof-lock" id="prof-lock">
      <span style="font-size:20px">🔐</span>
      <div>
        <div style="font-size:13px;font-weight:600;margin-bottom:4px">Área protegida</div>
        <div style="display:flex;gap:6px">
          <input type="password" id="prof-pwd2" placeholder="Senha do professor">
          <button onclick="unlockProf()">Entrar</button>
        </div>
        <div class="prof-lock-msg" id="prof-lock-msg">Senha incorreta!</div>
      </div>
    </div>

    <div id="prof-content" style="display:none">
      <div class="prof-tabs">
        <button class="prof-tab active" onclick="showProfTab('ranking')">🏆 Ranking</button>
        <button class="prof-tab" onclick="showProfTab('progresso')">📊 Progresso</button>
        <button class="prof-tab" onclick="showProfTab('perguntas')">💬 Perguntas <span id="qa-badge" style="background:var(--red);color:#fff;border-radius:999px;padding:1px 6px;font-size:10px;margin-left:4px;display:none">0</span></button>
      </div>
      <div id="prof-tab-ranking"></div>
      <div id="prof-tab-progresso" style="display:none"></div>
      <div id="prof-tab-perguntas" style="display:none"></div>
    </div>
  </div>
</div>

<script>
// ═══════════════════════════════════════════════════════════
// STORAGE — usa localStorage como banco de dados compartilhado
// Em produção use Supabase/Firebase. Aqui funciona no mesmo browser.
// ═══════════════════════════════════════════════════════════
var PROF_PWD = "prof123"; // MUDE AQUI a senha do professor

function db_get(key){ try{ return JSON.parse(localStorage.getItem(key)); }catch(e){ return null; } }
function db_set(key,val){ localStorage.setItem(key, JSON.stringify(val)); }

function getAllStudents(){
  var students = db_get("tc_students") || {};
  return students;
}
function saveStudent(name, data){
  var all = getAllStudents();
  all[name] = data;
  db_set("tc_students", all);
}
function getStudent(name){
  var all = getAllStudents();
  return all[name] || {name:name,stars:0,completed:[],errors:{},answers:{},questions:[]};
}
function getAllQuestions(){
  var all = getAllStudents();
  var qs = [];
  Object.values(all).forEach(function(s){
    (s.questions||[]).forEach(function(q){ qs.push(q); });
  });
  return qs.sort(function(a,b){ return b.time-a.time; });
}

// ═══════════════════════════════════════════════════════════
